# Dev local — cityPenha-back/docker-compose.yml (banco citypenha, sem WordPress).
# Produção VPS: ver infra/.env.example

NODE_ENV=development
TZ=America/Sao_Paulo
PORT=3000

DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_USER=citypenha
DATABASE_PASSWORD=citypenha
DATABASE_NAME=citypenha
DATABASE_URL=mysql://citypenha:citypenha@db:3306/citypenha
DATABASE_POOL_SIZE=5
DATABASE_CONNECT_TIMEOUT=10000

# WordPress REST (dev com stack infra/ ou mock)
ENV_API_WORDPRESS=http://wordpress-nginx:8080/wp-json/wp/v2
ENV_API_WORDPRESS_ADMIN_USER=admin
ENV_API_WORDPRESS_ADMIN_PASSWORD=CHANGE_ME_WP_APP_PASSWORD

# Firebase Admin (escolher UMA opção)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase.json

ADMIN_FIREBASE_UIDS=

DISCOVERY_WORLD_NEWS_CATEGORY_IDS=3,7,12
DISCOVERY_LIMIT_WORLD_NEWS=10
DISCOVERY_LIMIT_TRENDING=10
DISCOVERY_LIMIT_POPULAR_AUTHORS=10

AD_INTERVAL_MIN=4
AD_INTERVAL_MAX=5

LOG_LEVEL=info
LOG_SLOW_MS=3000
