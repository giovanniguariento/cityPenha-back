{
  "scripts": {
    "postinstall": "prisma generate",
    "start": "node dist/server.js",
    "start:dev": "tsx --env-file=.env --watch src/server.ts",
    "build": "pkgroll",
    "db:dev": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:resolve": "prisma migrate resolve",
    "db:baseline": "tsx --env-file=.env scripts/baseline-migrations.ts",
    "db:new": "tsx --env-file=.env scripts/new-migration.ts"
  },
  "type": "module",
  "main": "./dist/server.js",
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/adapter-mariadb": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.3.0",
    "multer": "^2.2.0",
    "php-serialize": "^5.1.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.0.9",
    "pkgroll": "^2.21.4",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
